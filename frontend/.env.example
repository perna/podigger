# Podigger Frontend — Environment Variables
# Copy this file to .env.local and fill in the values.
# See: specs/004-frontend-modernization/contracts/env-schema.md

# Required: Back-end API base URL.
# Use a full URL for direct access (e.g. http://localhost:8000)
# or a relative path to the local Next.js proxy (e.g. /api/proxy).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Default page size for episodes / podcasts list endpoints.
# Must be a positive integer. Defaults to 20.
# NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20

# Optional: Request timeout in milliseconds.
# Must be a positive integer. Defaults to 10000 (10 seconds).
# NEXT_PUBLIC_REQUEST_TIMEOUT_MS=10000
